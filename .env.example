# Supabase project URL (e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe for client-side use)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role key (NEVER expose to client; used by admin edge functions)
SUPABASE_SERVICE_ROLE_KEY=

# Tenor API key for GIF search (https://developers.google.com/tenor/guides/quickstart)
NEXT_PUBLIC_TENOR_API_KEY=
